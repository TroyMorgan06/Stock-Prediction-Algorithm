# Copy to: /etc/stock-ai/stock-ai.env
# Then: sudo chmod 600 /etc/stock-ai/stock-ai.env

# Alpaca credentials
APCA_API_KEY_ID=YOUR_KEY
APCA_API_SECRET_KEY=YOUR_SECRET

# Optional: keep these if you want to override defaults globally
# (alpaca_executor.py reads only the APCA vars; flags are in the systemd unit)
#
# PLAN_DOLLARS_PER_TRADE=5.0

